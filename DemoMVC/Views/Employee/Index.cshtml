@{
    ViewData["Title"] = "Employee CRUD";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

<div class="container mt-4">
    <h2>Employee List</h2>
    <button class="btn btn-primary mb-2" onclick="openModal()">Add Employee</button>

    <table class="table table-bordered" id="employeeTable">
        <thead>
            <tr>
                <th>Name</th>
                <th>Position</th>
                <th>Salary</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody></tbody>
    </table>
</div>

<!-- Modal -->
<div class="modal fade" id="employeeModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <form id="employeeForm">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Employee</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <input type="hidden" id="Id" name="Id" />
                    <div class="mb-3">
                        <label for="Name">Name</label>
                        <input class="form-control" name="Name" id="Name" required />
                    </div>
                    <div class="mb-3">
                        <label for="Position">Position</label>
                        <input class="form-control" name="Position" id="Position" />
                    </div>
                    <div class="mb-3">
                        <label for="Salary">Salary</label>
                        <input class="form-control" name="Salary" id="Salary" type="number" />
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="submit" class="btn btn-success">Save</button>
                    <button class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
                </div>
            </div>
        </form>
    </div>
</div>

<script>
    $(document).ready(function () {
        loadEmployees();

        $('#employeeForm').on('submit', function (e) {
            e.preventDefault();
            const data = $(this).serialize();
            const isUpdate = $('#Id').val();

            $.post(isUpdate ? '/Employee/Update' : '/Employee/Create', data, function (res) {
                if (res.success) {
                    $('#employeeModal').modal('hide');
                    loadEmployees();
                } else {
                    alert('Failed to save employee.');
                }
            });
        });
    });

    function loadEmployees() {
        $.get('/Employee/GetEmployees', function (data) {
            let rows = '';
            data.forEach(emp => {
                rows += `<tr>
                    <td>${emp.name}</td>
                    <td>${emp.position}</td>
                    <td>${emp.salary}</td>
                    <td>
                        <button class="btn btn-sm btn-warning" onclick='editEmployee(${JSON.stringify(emp)})'>Edit</button>
                        <button class="btn btn-sm btn-danger" onclick='deleteEmployee(${emp.id})'>Delete</button>
                    </td>
                </tr>`;
            });
            $('#employeeTable tbody').html(rows);
        });
    }

    function openModal() {
        $('#employeeForm')[0].reset();
        $('#Id').val('');
        new bootstrap.Modal(document.getElementById('employeeModal')).show();
    }

    function editEmployee(emp) {
        $('#Id').val(emp.id);
        $('#Name').val(emp.name);
        $('#Position').val(emp.position);
        $('#Salary').val(emp.salary);
        new bootstrap.Modal(document.getElementById('employeeModal')).show();
    }

    function deleteEmployee(id) {
        if (confirm('Are you sure?')) {
            $.post('/Employee/Delete', { id: id }, function (res) {
                if (res.success) loadEmployees();
                else alert('Delete failed.');
            });
        }
    }
</script>
